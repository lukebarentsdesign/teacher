// Peripatetic Teacher App — Prisma schema
// Reference: peripatetic-teacher-app-spec.md sections 2-3
// NextAuth uses Credentials + JWT sessions (no OAuth), so no Account/Session/VerificationToken tables are needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TaxHandling {
  SELF_EMPLOYED
  PAYE_VIA_SCHOOL
}

enum InvoicingTarget {
  SCHOOL
  PARENT
}

enum SchedulingMode {
  FIXED
  FLUID
}

enum ChargeUnit {
  PER_BOOKING
  PER_HOUR
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum StudentSource {
  HOME
  SCHOOL_INQUIRY
  COLLEGE
}

enum StudentStatus {
  PENDING_REVIEW
  ACTIVE
  DECLINED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
}

enum BillingModel {
  SMOOTHED_SUBSCRIPTION
  PER_LESSON
  HOURLY
  TERMLY
}

enum LessonStatus {
  HELD
  CANCELLED_BY_STUDENT
  CANCELLED_BY_TEACHER
  RESCHEDULED
}

enum LedgerReason {
  PAYMENT
  LESSON_DELIVERED
  CANCELLATION_ADJUSTMENT
  MANUAL_CORRECTION
  MAKE_UP_CREDIT_ISSUED
  MAKE_UP_CREDIT_REDEEMED
  VENUE_FEE_ITEMISED
  LATE_CANCELLATION_CHARGE
}

/// What happens when a lesson is cancelled/no-showed, governed by a CancellationPolicy. CREDIT is
/// the app's original (and still the no-policy-configured default) behavior: bank a make-up
/// lesson, no cash impact. The other three are new — see src/lib/cancellation-policy.ts.
enum CancellationAction {
  FULL_CHARGE
  PARTIAL_CHARGE
  CREDIT
  FORFEIT
}

enum VenueFeeType {
  FLAT_PER_SESSION
  PERCENT_OF_LESSON_FEE
  PERIOD_RENTAL
}

/// ABSORBED_INTO_FEE (default): the venue cost is the teacher's own overhead, priced into
/// LessonType/LessonTypeLocationPricing directly, never itemised to the parent. ITEMISED_TO_PAYER:
/// the rare opt-in where the teacher wants it broken out as its own ledger line.
enum VenueFeeBillingMode {
  ABSORBED_INTO_FEE
  ITEMISED_TO_PAYER
}

enum LedgerOperation {
  CREDIT // + payment received / make-up credit issued
  DEBIT // - lesson consumed / refund / credit redeemed
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// Teacher's own platform (SaaS) subscription status — Learnio billing them, not lesson billing.
enum PlatformSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ResourceType {
  DOCUMENT
  AUDIO
  VIDEO
}

enum AssignmentStatus {
  ASSIGNED
  REVIEWED_DONE
  REVIEWED_NOT_DONE
}

enum PrivateTuitionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ContactPref {
  WHATSAPP
  SMS
  EMAIL
}

enum MedicalNoteSeverity {
  LOW
  MEDIUM
  HIGH
}

enum GroupBookingStatus {
  CONFIRMED
  WAITLISTED
  CANCELLED
}

enum StudentCurriculumStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum StudentCurriculumSectionStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum LocationType {
  SCHOOL
  STUDENT_HOME
  TEACHER_BASE
  HIRED_VENUE
  ONLINE
  OTHER
}

enum TeacherRole {
  OWNER
  INSTRUCTOR
}

/// The tenancy boundary above Teacher (roadmap v2 Part 6e) — deliberately conservative in scope.
/// Grouping Teacher accounts under one Organisation does NOT change the existing per-Teacher
/// tenancy boundary on Student/Payer/etc. (still `teacherId`, unchanged everywhere) — a
/// full shared-roster model (any instructor in the org sees all org students) is a much bigger
/// change than this pass makes, deliberately not attempted. What Organisation adds: account
/// grouping, and CoverAssignment for one instructor to cover another's lesson without any
/// ownership transfer of the underlying Student/Payer/Subscription records.
model Organisation {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teachers Teacher[]
  invites  OrganisationInvite[]
}

/// Consent-based join — same "generate a link, the other person actively accepts" pattern as
/// self-serve onboarding/embed links elsewhere in this app, rather than an OWNER unilaterally
/// attaching another Teacher's account. Only acceptable while the invitee has no organisation yet.
model OrganisationInvite {
  id                String    @id @default(cuid())
  organisationId    String
  invitedByTeacherId String
  token             String    @unique
  createdAt         DateTime  @default(now())
  acceptedAt        DateTime?

  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  invitedByTeacher Teacher     @relation(fields: [invitedByTeacherId], references: [id], onDelete: Cascade)
}

/// Substitute/cover for a specific Lesson — the covering instructor must be in the same
/// Organisation as the original. Doesn't transfer ownership of the Lesson/Student/Subscription;
/// purely a record of who actually taught it, for the org's own reference.
model CoverAssignment {
  id                    String    @id @default(cuid())
  originalInstructorId  String
  coveringInstructorId  String
  lessonId              String?
  reason                String?
  createdAt             DateTime  @default(now())

  originalInstructor Teacher @relation("CoverOriginal", fields: [originalInstructorId], references: [id], onDelete: Cascade)
  coveringInstructor Teacher @relation("CoverCovering", fields: [coveringInstructorId], references: [id], onDelete: Cascade)
  lesson             Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([lessonId])
}

/// Home-visit safety check-in/check-out (roadmap v2 Part 9b) — for a teacher travelling alone to
/// a student's home, not other location types. No cron/background-job infra exists in this app
/// (same constraint noted for AccountingExport/InstructorCertification elsewhere), so the overdue
/// check is lazy/request-triggered — see checkAndSendLoneWorkerAlerts in src/lib/lone-worker.ts,
/// called from GET /api/today (the page a teacher actually has open while out teaching). This is
/// a best-effort heuristic, not a guaranteed real-time alert — documented honestly, not glossed over.
model LoneWorkerCheckIn {
  id            String    @id @default(cuid())
  lessonId      String    @unique
  checkedInAt   DateTime?
  checkedOutAt  DateTime?
  expectedEndAt DateTime
  graceMinutes  Int       @default(15)
  alertSentAt   DateTime?
  createdAt     DateTime  @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Teacher / TeachingLocation / scheduling
// ---------------------------------------------------------------------------

model Teacher {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Learnio's own SaaS billing of the teacher — separate from lesson/ledger billing.
  stripeCustomerId       String?                    @unique
  platformSubscriptionId String?                    @unique
  platformStatus         PlatformSubscriptionStatus @default(TRIALING)

  /// Stripe Connect Express account so parent payments land with the teacher, not Learnio.
  stripeConnectAccountId String? @unique
  stripeConnectOnboarded Boolean @default(false)

  /// Used for home-sourced students' calendar events, when no TeachingLocation.primaryColor applies.
  personalBrandLogoUrl String?
  personalBrandColor   String?

  /// Lone-worker safety (roadmap v2 Part 9b) — who gets alerted if a home-visit check-out doesn't
  /// happen within the expected window. Deliberately separate from the guardian-facing Payer
  /// contact fields; this is the teacher's own safety contact, never shown to a parent/student.
  emergencyContactName  String?
  emergencyContactPhone String?
  emergencyContactEmail String?

  /// Multi-instructor grouping (roadmap v2 Part 6e) — null organisationId is the default and
  /// normal state (a standalone teacher, exactly today's behavior). role only means something once
  /// organisationId is set; OWNER is the default so a Teacher who starts an Organisation is
  /// automatically its owner rather than needing a separate promotion step.
  organisationId String?
  role           TeacherRole @default(OWNER)
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  sentOrganisationInvites OrganisationInvite[]
  coverAssignmentsAsOriginal CoverAssignment[] @relation("CoverOriginal")
  coverAssignmentsAsCovering CoverAssignment[] @relation("CoverCovering")

  /// Whether a Subscription's banked creditAppliedNextPeriod auto-reduces the suggested amount
  /// on the next manually-generated payment request, or is only displayed for the teacher to
  /// account for themselves. See "Credit application" in the no-show/make-up-credit build notes.
  autoApplyCreditToNextPayment Boolean @default(true)

  /// Teacher's own Gmail, connected via a separate OAuth grant (NOT the NextAuth login provider —
  /// login stays Credentials-only). Lets guardian emails be sent from the teacher's real address
  /// instead of a generic sender. gmailRefreshTokenEncrypted is a real bearer secret (unlike the
  /// Stripe fields above, which are non-secret account IDs) — encrypted at rest, see src/lib/encryption.ts.
  gmailConnected             Boolean   @default(false)
  gmailConnectedEmail        String?
  gmailRefreshTokenEncrypted String?
  gmailTokenUpdatedAt        DateTime?

  locationLinks         TeacherLocationLink[]
  unavailability        Unavailability[]
  lessons               Lesson[]
  groupClasses          GroupClass[]
  assessments           Assessment[]
  packages              Package[]
  loanableItems         LoanableItem[]
  students              Student[]
  payers                Payer[]
  contracts             Contract[]
  resources             Resource[]
  assignments           Assignment[]
  maintenanceReminders  MaintenanceReminder[]
  expenses              Expense[]
  privateTuitionRequests PrivateTuitionRequest[]
  addOns                 AddOn[]
  subjects                Subject[]
  lessonTypes             LessonType[]
  termCalendars           TermCalendar[]
  curriculumTemplates     CurriculumTemplate[]
  sessionPlanTemplates    SessionPlanTemplate[]
  certifications          InstructorCertification[]
  incidentLogs            IncidentLog[]
  cancellationPolicies    CancellationPolicy[]
  giftCards               GiftCard[]
  promoCodes              PromoCode[]
  embedConfigs            EmbedConfig[]
  courses                 Course[]
  courseItems             CourseItem[]
}

model TeachingLocation {
  id              String          @id @default(cuid())
  name            String
  locationType    LocationType    @default(SCHOOL)
  address         String?
  invoicingTarget InvoicingTarget
  /// Legacy single-term scalars, kept as a fallback for locations with no TermCalendar assigned.
  /// The richer TermCalendar (below) supersedes these when set — the bulk timetable generator
  /// prefers a TermCalendar's TermPeriods (so half-terms/holidays are excluded) and only falls
  /// back to termStart/termEnd when no calendar is attached.
  termStart       DateTime?
  termEnd         DateTime?
  /// Optional assigned term calendar. "Inherit a default" = point at a shared TermCalendar reused
  /// across locations; "its own override" (spec 4.5) = point at a location-specific TermCalendar.
  /// Modeled as an assignment rather than a diff-on-top of a base, since merge semantics (which
  /// dates win) would be ambiguous — a location with adjusted dates simply gets its own calendar.
  termCalendarId  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  /// Optional branding, used to color this location's lessons on the teacher's calendar views.
  logoUrl       String?
  primaryColor  String?
  secondaryColor String?

  /// Free-text WiFi codes, door entry codes, parking instructions, reception contact etc. —
  /// visible to the teacher (and any other teacher assigned to this location) but never exposed
  /// to parents/students in any UI.
  accessNotes String?

  /// Unguessable token for the public, no-login "Now/Next" session-plan display view (a venue TV
  /// or tablet) — generated on demand, not present by default. Unlike accessNotes this IS meant
  /// to be shown publicly (it's the room's own agenda), just not tied to any parent/student login.
  displayToken String? @unique

  teacherLinks   TeacherLocationLink[]
  rooms          Room[]
  students       Student[]
  unavailability Unavailability[]
  lessons        Lesson[]
  groupClasses   GroupClass[]
  loanableItems  LoanableItem[]
  privateTuitionRequestsAsSource PrivateTuitionRequest[]
  /// Which LessonTypes are offered here — see LessonType.locations for the "scoped to specific
  /// venues" semantics (empty on the LessonType side = offered everywhere, not "offered nowhere").
  lessonTypes    LessonType[]
  venueFeeArrangements VenueFeeArrangement[]
  lessonTypePricing    LessonTypeLocationPricing[]
  termCalendar   TermCalendar? @relation(fields: [termCalendarId], references: [id], onDelete: SetNull)
  cancellationPolicy CancellationPolicy?
  embedConfigs   EmbedConfig[]
}

/// A reusable term-dates template (e.g. "Standard England LA terms 2026/27"). UK term dates are
/// set per Local Authority (and independently by private schools) with no single national feed, so
/// this is teacher-entered configuration, not pulled from an API. One TermCalendar can be shared
/// across many TeachingLocations, or a location can have its own (see TeachingLocation.termCalendar).
model TermCalendar {
  id        String   @id @default(cuid())
  teacherId String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher   Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  terms     TermPeriod[]
  holidays  HolidayPeriod[]
  locations TeachingLocation[]

  @@index([teacherId])
}

/// One teaching term within a TermCalendar (Autumn/Spring/Summer). The bulk generator schedules
/// within [startDate, endDate], minus any HolidayPeriod that overlaps.
model TermPeriod {
  id             String   @id @default(cuid())
  termCalendarId String
  name           String
  startDate      DateTime
  endDate        DateTime

  termCalendar TermCalendar @relation(fields: [termCalendarId], references: [id], onDelete: Cascade)

  @@index([termCalendarId])
}

/// A half-term / holiday / inset window excluded from candidate lesson dates.
model HolidayPeriod {
  id             String   @id @default(cuid())
  termCalendarId String
  name           String
  startDate      DateTime
  endDate        DateTime

  termCalendar TermCalendar @relation(fields: [termCalendarId], references: [id], onDelete: Cascade)

  @@index([termCalendarId])
}

/// A teacher-defined "menu" of what they teach (e.g. "Flute — Beginner", "Flute — Grade 3+") —
/// the foundation both onboarding entry points (direct wizard and the self-serve questionnaire)
/// need something for a student to choose from.
model LessonType {
  id                     String   @id @default(cuid())
  teacherId              String
  name                   String
  description            String?
  defaultDurationMinutes Int
  defaultFee             Decimal  @db.Decimal(10, 2)
  active                 Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  /// Optional scoping to specific venues (e.g. group flute only at School A, private flute only
  /// at home) — an EMPTY set here means "offered everywhere", not "offered nowhere". Only treat
  /// this as a filter when non-empty; see how onboarding/the self-serve link use it.
  locations TeachingLocation[]
  requestedByStudents Student[]
  locationPricing LessonTypeLocationPricing[]
  curriculumTemplates CurriculumTemplate[]
  promoCodes PromoCode[]
  embedConfigs EmbedConfig[]
  courseItems CourseItem[]

  @@unique([teacherId, name])
  @@index([teacherId])
}

/// A cost the teacher pays to use a venue (hall hire, gym rental, etc.) — purely a record against
/// the teacher, feeding income forecasting. Has NO automatic effect on what's billed to the
/// parent unless billingMode is explicitly set to ITEMISED_TO_PAYER (rare — see that enum's doc).
/// Default expectation is the teacher absorbs this into LessonType/LessonTypeLocationPricing
/// pricing themselves.
model VenueFeeArrangement {
  id          String              @id @default(cuid())
  locationId  String
  feeType     VenueFeeType
  amount      Decimal             @db.Decimal(10, 2)
  billingMode VenueFeeBillingMode @default(ABSORBED_INTO_FEE)
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  location TeachingLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
}

/// Per-location override of LessonType.defaultFee — e.g. Flute taught from a music college costs
/// £30, the same LessonType taught from home costs £20. The teacher sets these directly, already
/// factoring in their own venue cost; no split/derivation logic reads VenueFeeArrangement to
/// compute this automatically.
model LessonTypeLocationPricing {
  id           String  @id @default(cuid())
  lessonTypeId String
  locationId   String
  fee          Decimal @db.Decimal(10, 2)

  lessonType LessonType       @relation(fields: [lessonTypeId], references: [id], onDelete: Cascade)
  location   TeachingLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([lessonTypeId, locationId])
}

/// A Teacher's engagement with one TeachingLocation/Venue: scheduling mode, availability,
/// tax handling and protected blocks all vary per link, not globally.
model TeacherLocationLink {
  id             String         @id @default(cuid())
  teacherId      String
  locationId     String
  schedulingMode SchedulingMode
  taxHandling    TaxHandling

  /// Array of { dayOfWeek, startTime, endTime }
  availability Json

  /// Array of { dayOfWeek, startTime, endTime, label } — periods that must never be scheduled
  protectedBlocks Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher  Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location TeachingLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([teacherId, locationId])
}

/// Teacher-declared unavailability window. On confirmation, affected Lessons/GroupClasses
/// are auto-cancelled, guardians are emailed, and ledger credits are posted.
model Unavailability {
  id            String    @id @default(cuid())
  teacherId     String
  locationId    String? // null = spans all locations
  startDatetime DateTime
  endDatetime   DateTime
  reason        String?
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())

  teacher  Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location TeachingLocation? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([teacherId, startDatetime, endDatetime])
}

model Room {
  id         String @id @default(cuid())
  locationId String
  label      String

  /// e.g. { hasPiano: true, hasMirrors: false, floor: "1st" }
  features Json @default("{}")

  /// Weekly open/closed days + time windows: array of { dayOfWeek, openTime, closeTime }
  openHours Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  location     TeachingLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  groupClasses GroupClass[]
  assessments  Assessment[]
}

// ---------------------------------------------------------------------------
// Students / Guardians / Payers
// ---------------------------------------------------------------------------

model Student {
  id         String        @id @default(cuid())
  /// Owning teacher — the core multi-tenant boundary. A Student belongs to exactly one teacher.
  teacherId  String
  name       String
  dob        DateTime?
  discipline String // instrument / class / discipline
  source     StudentSource
  locationId String? // null for home students
  igCardId   String? // links to existing IG Card wallet pass, for CheckIn scanning only
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  /// PENDING_REVIEW = created via the self-serve onboarding questionnaire, not yet a confirmed
  /// enrolment — the teacher must approve before it's ACTIVE. Directly-created (wizard) students
  /// skip straight to ACTIVE. DECLINED is a soft-reject, kept for record rather than deleted.
  status StudentStatus @default(ACTIVE)

  /// Which LessonType a self-serve submission expressed interest in — informational only, shown
  /// on the teacher's review screen; not a durable enrolment record (a Student isn't tied to one
  /// LessonType long-term once active, they may end up scheduled across several).
  requestedLessonTypeId String?
  requestedLessonType   LessonType? @relation(fields: [requestedLessonTypeId], references: [id], onDelete: SetNull)

  /// Only settable true if the student is 16+ (checked against dob when toggled on, not
  /// continuously enforced). Grants a second, independent microsite login — additive to the
  /// guardian's own access, never a replacement. Under-16 students: no exceptions.
  hasIndependentAccess Boolean @default(false)

  /// Second 6-digit code, drawn from the same flat namespace as Payer.accessCode (one login
  /// screen accepts either kind of code) — see src/lib/access-code.ts for cross-model uniqueness.
  studentAccessCode          String?   @unique
  studentAccessCodeUpdatedAt DateTime?

  /// Financial ledger/balance is hidden from the student's own view unless the guardian
  /// explicitly opts in. Never affects the guardian's own visibility, which is always full.
  shareBalanceWithStudent Boolean @default(false)

  teacher           Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location          TeachingLocation?  @relation(fields: [locationId], references: [id])
  payerLinks        StudentPayerLink[]
  subscriptions     Subscription[]
  packages          Package[]
  lessons           Lesson[]
  groupClassMembers GroupClassMember[]
  checkIns          CheckIn[]
  assessments       Assessment[]
  loans             Loan[]
  resources         Resource[]
  assignments       Assignment[]
  privateTuitionRequests PrivateTuitionRequest[]
  makeUpLessons     MakeUpLesson[]
  /// Zero-or-more subjects this student is taught, drawn from the teacher's own Subject list —
  /// additive to (not a replacement for) the free-text `discipline` field above, which stays as
  /// the original single-value description shown throughout the app. Lets a student span more
  /// than one subject (e.g. Piano + Music Theory) and be grouped/filtered by any of them.
  subjects          Subject[]
  curricula         StudentCurriculum[]
  groupSessionBookings GroupSessionBooking[]
  medicalNotes      StudentMedicalNote[]
  incidentLogs      IncidentLog[]

  @@index([teacherId])
}

/// A subject/discipline the teacher offers (e.g. Flute, Sax, Piano, or Yoga, Gymnastics),
/// teacher-defined so it matches whatever they actually teach. Used to tag Students (many-to-many)
/// so the teacher can group students — and, by extension, the lessons they need — by subject.
model Subject {
  id        String   @id @default(cuid())
  teacherId String
  name      String
  createdAt DateTime @default(now())

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  students    Student[]
  groupClasses GroupClass[]

  @@unique([teacherId, name])
  @@index([teacherId])
}

/// A guardian/student microsite request to convert a school-sourced Student into a private
/// (HOME-sourced) relationship. Acceptance is additive — creates a NEW Student row rather than
/// mutating the existing school-linked one, since school and private are separate billing
/// relationships that may coexist (e.g. still enrolled at the school, now also private).
model PrivateTuitionRequest {
  id               String                      @id @default(cuid())
  studentId        String
  teacherId        String
  sourceLocationId String
  status           PrivateTuitionRequestStatus @default(PENDING)
  requestedAt      DateTime                    @default(now())
  /// Set on acceptance — the new HOME-sourced Student created as a result, for traceability.
  resultingStudentId String?

  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher        Teacher          @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sourceLocation TeachingLocation @relation(fields: [sourceLocationId], references: [id])

  @@index([studentId, status])
}

model Payer {
  id        String   @id @default(cuid())
  /// Owning teacher — same tenancy boundary as Student. A family with two Learnio teachers
  /// (e.g. piano + yoga) gets one Payer record per teacher relationship, not one shared globally.
  teacherId String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Persistent unique 6-digit microsite access code (unique per family, not shared globally)
  accessCode          String   @unique
  accessCodeUpdatedAt DateTime @default(now())

  /// True when this Payer record IS the adult (18+) student paying for their own tuition — created
  /// by the new-student wizard's self-pay branch from the student's own contact details.
  isSelf Boolean @default(false)

  /// True for a safeguarding/emergency contact captured for an under-18 student whose SCHOOL is
  /// billed — has no billing role (never carries a Subscription), just contact + notes, so
  /// guardian info exists without implying they're invoiced. Distinct from a normal paying Payer.
  isEmergencyContactOnly Boolean @default(false)

  /// Preferred contact channel; notes is freeform (also holds address, which has no dedicated column).
  contactPref ContactPref?
  notes       String?

  teacher             Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentLinks        StudentPayerLink[]
  subscriptions       Subscription[]
  contractAcceptances ContractAcceptance[]
  lessonFeedback      LessonFeedback[]
  giftCardsPurchased  GiftCard[]
  coursePurchases     CoursePurchase[]

  @@index([teacherId])
}

model StudentPayerLink {
  id           String   @id @default(cuid())
  studentId    String
  payerId      String
  isPrimary    Boolean  @default(true)
  splitPercent Decimal? @db.Decimal(5, 2) // used when more than one payer splits a student's bill
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payer   Payer   @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@unique([studentId, payerId])
}

// ---------------------------------------------------------------------------
// Billing: Subscription / Package / Ledger / Payment
// ---------------------------------------------------------------------------

model Subscription {
  id           String             @id @default(cuid())
  studentId    String
  payerId      String
  annualFee    Decimal            @db.Decimal(10, 2)
  billingModel BillingModel
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?

  stripeSubscriptionId String? @unique
  stripeCustomerId     String?

  /// Banked from resolved no-shows via the "Review term absences" screen — see
  /// src/lib/ledger.ts and the payment-request flow for how this reduces (or is displayed
  /// alongside, per Teacher.autoApplyCreditToNextPayment) the next manually-generated payment.
  creditAppliedNextPeriod Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payer         Payer         @relation(fields: [payerId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
  payments      Payment[]
  lessons       Lesson[]
}

/// Prepaid block of N lessons at a discounted bundle rate. Distinct from Subscription —
/// no monthly smoothing, no running balance across the year.
model Package {
  id               String   @id @default(cuid())
  studentId        String
  teacherId        String
  totalLessons     Int
  lessonsRemaining Int
  price            Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

/// Running-balance ledger. Balance for a Subscription = sum of CREDIT entries minus DEBIT entries.
model LedgerEntry {
  id             String          @id @default(cuid())
  subscriptionId String
  amount         Decimal         @db.Decimal(10, 2)
  operation      LedgerOperation
  reason         LedgerReason
  date           DateTime        @default(now())
  note           String?
  createdAt      DateTime        @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, date])
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  stripePaymentId String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus
  date            DateTime      @default(now())
  createdAt       DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

/// Teacher-tracked business expense, for the income forecasting dashboard's expense-tracking line.
model Expense {
  id        String   @id @default(cuid())
  teacherId String
  amount    Decimal  @db.Decimal(10, 2)
  category  String
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, date])
}

/// One evolving document per teacher (not per subscription) — a teacher's standard terms apply
/// across all their students. Editing the contract creates a new version; content is never
/// mutated in place, since ContractAcceptance snapshots must stay meaningful against history.
model Contract {
  id        String   @id @default(cuid())
  teacherId String
  version   Int
  content   String // plain-terms explanation of the subscription/ledger model
  createdAt DateTime @default(now())

  teacher     Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  acceptances ContractAcceptance[]

  @@unique([teacherId, version])
}

/// The actual mechanism of legal agreement — an in-app clickwrap acceptance, not a PDF/e-signature
/// round-trip. Gates lesson booking and payment collection on a Subscription until the
/// Subscription's payer has accepted the teacher's *current* Contract version.
model ContractAcceptance {
  id      String @id @default(cuid())
  payerId String

  contractId      String
  /// Denormalized so "did they accept the current version" is a direct comparison, not a join.
  contractVersion Int

  /// Independent copy of the exact text shown at acceptance time — deliberately not just a
  /// foreign key to Contract.content, so a later edit to the live contract can never retroactively
  /// change what a past acceptance recorded as having been agreed to.
  contractSnapshot String

  typedName  String
  acceptedAt DateTime @default(now())
  ipAddress  String?

  payer    Payer    @relation(fields: [payerId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id])

  @@unique([payerId, contractVersion])
  @@index([payerId])
}

// ---------------------------------------------------------------------------
// Lessons / GroupClasses / CheckIn
// ---------------------------------------------------------------------------

model Lesson {
  id             String       @id @default(cuid())
  studentId      String
  teacherId      String
  locationId     String
  roomId         String?
  subscriptionId String?
  packageId      String?
  scheduledAt    DateTime
  durationMins   Int
  status         LessonStatus @default(HELD)

  /// Mirrors ELVIS's are_hours_counted — false for a cover/make-up lesson so it doesn't double-bill
  hoursCounted Boolean @default(true)

  /// Set via the "Absent, make-up owed" attendance action — a confirmed no-show, distinct from
  /// simply never having marked attendance at all. Feeds the MakeUpLesson tracking row created
  /// alongside it and the "Review term absences" screen.
  noShowReason    String?
  noShowConfirmed Boolean @default(false)

  /// Teacher-supplied meeting link (Zoom/Meet/Teams/etc.) used when the parent TeachingLocation's
  /// locationType is ONLINE — MVP deliberately skips API-based meeting creation (no OAuth/API
  /// setup overhead until there's real usage to justify it), see CLAUDE.md "Online Lessons" notes.
  meetingUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student            Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location           TeachingLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  room               Room?             @relation(fields: [roomId], references: [id])
  subscription       Subscription?  @relation(fields: [subscriptionId], references: [id])
  package            Package?       @relation(fields: [packageId], references: [id])
  addOnBookings      AddOnBooking[]
  checkIn            CheckIn?
  note               LessonNote?
  resources          Resource[]
  makeUpLessonAsOriginal MakeUpLesson? @relation("OriginalLesson")
  makeUpLessonAsMakeUp   MakeUpLesson? @relation("MakeUpLessonSlot")
  sessionPlan        SessionPlan?
  incidentLogs       IncidentLog[]
  feedback           LessonFeedback[]
  coverAssignments   CoverAssignment[]
  loneWorkerCheckIn  LoneWorkerCheckIn?

  @@index([teacherId, scheduledAt])
  @@index([studentId, scheduledAt])
}

/// Tracks a confirmed no-show from marking-it through to resolution — either a rescheduled
/// make-up lesson, or (via the "Review term absences" screen) converted into a next-period
/// billing credit. Created alongside the MAKE_UP_CREDIT_ISSUED ledger entry when a lesson is
/// marked "Absent, make-up owed", so the credit isn't just a floating ledger row.
model MakeUpLesson {
  id              String    @id @default(cuid())
  originalLessonId String   @unique
  makeUpLessonId  String?   @unique
  studentId       String
  requestedAt     DateTime  @default(now())
  confirmedAt     DateTime?
  completedAt     DateTime?

  originalLesson Lesson  @relation("OriginalLesson", fields: [originalLessonId], references: [id], onDelete: Cascade)
  makeUpLesson   Lesson? @relation("MakeUpLessonSlot", fields: [makeUpLessonId], references: [id])
  student        Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, completedAt])
}

/// Freetext note per lesson — what was covered, what to work on next. Visible to the guardian
/// always, and to the student too if they have independent access (not gated by
/// shareBalanceWithStudent — that toggle is specifically about the financial ledger).
model LessonNote {
  id        String   @id @default(cuid())
  lessonId  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Optional link to the curriculum section this lesson's note relates to — lets a note say
  /// "worked on Section 3" without requiring a curriculum to exist at all.
  studentCurriculumSectionId String?

  lesson                  Lesson                    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  studentCurriculumSection StudentCurriculumSection? @relation(fields: [studentCurriculumSectionId], references: [id], onDelete: SetNull)
}

model GroupClass {
  id         String  @id @default(cuid())
  teacherId  String
  locationId String
  roomId     String?
  name       String
  discipline String
  /// Optional link into the teacher-defined Subject list (same one Student tags draw from), so a
  /// group class can be grouped/filtered alongside the students who share that subject. Additive
  /// to `discipline` above for the same reason Student kept its own free-text field — see
  /// "Subject Decisions" in CLAUDE.md.
  subjectId  String?

  dayOfWeek Int // 0-6, recurs weekly
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  /// Null = unlimited. When set, self-service bookings (GroupSessionBooking) beyond this many
  /// CONFIRMED per session date are WAITLISTED instead, promoted automatically as spots free up.
  /// Standing GroupClassMember rows are not counted against this — capacity governs per-session
  /// bookings, not the class's overall roster.
  capacity Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher       Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location      TeachingLocation   @relation(fields: [locationId], references: [id], onDelete: Cascade)
  room          Room?              @relation(fields: [roomId], references: [id])
  subject       Subject?           @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  members       GroupClassMember[]
  checkIns      CheckIn[]
  addOnBookings AddOnBooking[]
  bookings      GroupSessionBooking[]
  /// GroupClass has no dated per-occurrence row (see CheckIn's "attendance-only, no dated
  /// instance to bill" note elsewhere) — so unlike Lesson's one-to-one SessionPlan, a recurring
  /// class can accumulate several over time. The most recently created one is treated as "current".
  sessionPlans  SessionPlan[]
}

/// A booking into one specific dated occurrence of a recurring GroupClass — distinct from
/// GroupClassMember's standing membership (which has no notion of a single date). Since GroupClass
/// itself has no dated per-occurrence row, sessionDate is the booking's own record of which
/// occurrence it's for.
model GroupSessionBooking {
  id           String              @id @default(cuid())
  groupClassId String
  studentId    String
  sessionDate  DateTime            @db.Date
  status       GroupBookingStatus  @default(CONFIRMED)
  bookedAt     DateTime            @default(now())

  groupClass GroupClass @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupClassId, studentId, sessionDate])
  @@index([groupClassId, sessionDate])
}

/// Each member keeps their own independent Subscription/Ledger even though they share a timeslot.
model GroupClassMember {
  id           String    @id @default(cuid())
  groupClassId String
  studentId    String
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?

  groupClass GroupClass @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupClassId, studentId])
}

/// Card-based sign-in/out. Scanning on sign-in auto-fires the LESSON_DELIVERED ledger entry.
model CheckIn {
  id           String    @id @default(cuid())
  lessonId     String?   @unique
  groupClassId String?
  studentId    String
  signedInAt   DateTime?
  signedOutAt  DateTime?
  createdAt    DateTime  @default(now())

  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  groupClass GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([groupClassId, studentId])
}

// ---------------------------------------------------------------------------
// Add-ons
// ---------------------------------------------------------------------------

model AddOn {
  id         String     @id @default(cuid())
  teacherId  String
  name       String
  price      Decimal    @db.Decimal(10, 2)
  chargeUnit ChargeUnit
  visibility Visibility @default(PUBLIC)
  archivedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  teacher  Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  bookings AddOnBooking[]

  @@index([teacherId])
}

/// Attaches an AddOn to a Lesson or GroupClass booking without touching the core billing model.
model AddOnBooking {
  id           String   @id @default(cuid())
  addOnId      String
  lessonId     String?
  groupClassId String?
  quantity     Int      @default(1)
  priceAtTime  Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  addOn      AddOn       @relation(fields: [addOnId], references: [id])
  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  groupClass GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Assessments / Loans
// ---------------------------------------------------------------------------

model Assessment {
  id          String   @id @default(cuid())
  studentId   String
  teacherId   String
  level       String // grade/level achieved
  date        DateTime
  canContinue Boolean  @default(true)

  /// Set when this is a formal sit-down evaluation rather than an informal note
  appointmentAt DateTime?
  roomId        String?

  examBoard String? // e.g. Trinity, ABRSM
  examFee   Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  room    Room?   @relation(fields: [roomId], references: [id])
}

/// A shared library item (document/audio/video). Attachable to a Student generally (a library
/// item for them), to a specific Lesson, or left unattached in the teacher's general library
/// until an Assignment references it via Assignment.resourceId.
model Resource {
  id          String       @id @default(cuid())
  teacherId   String
  type        ResourceType
  title       String
  url         String
  description String?
  studentId   String?
  lessonId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student     Student?     @relation(fields: [studentId], references: [id])
  lesson      Lesson?      @relation(fields: [lessonId], references: [id])
  assignments Assignment[]
}

/// A personal routine/exercise a teacher assigns one student between lessons, reviewed at the next one.
model Assignment {
  id           String           @id @default(cuid())
  studentId    String
  teacherId    String
  title        String
  instructions String
  target       String
  assignedDate DateTime
  reviewDate   DateTime
  resourceId   String?
  status       AssignmentStatus @default(ASSIGNED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resourceId], references: [id])

  @@index([studentId])
}

model LoanableItem {
  id        String   @id @default(cuid())
  name      String
  type      String // instrument / book / CD / etc.
  condition String?
  value     Decimal? @db.Decimal(10, 2)
  teacherId String? // owned by Teacher or TeachingLocation (exactly one should be set)
  locationId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher              Teacher?              @relation(fields: [teacherId], references: [id])
  location             TeachingLocation?     @relation(fields: [locationId], references: [id])
  loans                Loan[]
  maintenanceReminders MaintenanceReminder[]
}

model Loan {
  id             String    @id @default(cuid())
  itemId         String
  studentId      String
  checkedOutDate DateTime  @default(now())
  dueBackDate    DateTime
  returnedDate   DateTime?
  conditionNotes String?

  item    LoanableItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

/// Upkeep reminder on equipment, owned or loaned. Not every reminder needs a formal LoanableItem
/// (itemDescription covers ad hoc equipment) — when it IS linked to one that's currently on loan
/// to a student, it surfaces in that student's microsite; unlinked reminders stay teacher-only.
model MaintenanceReminder {
  id              String   @id @default(cuid())
  teacherId       String
  loanableItemId  String?
  itemDescription String
  dueDate         DateTime
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  loanableItem LoanableItem? @relation(fields: [loanableItemId], references: [id])
}

/// Teacher's own reusable syllabus (e.g. "Flute Grade 1 — standard"), built once and applied to any
/// student following that path. Purely a template — importing onto a student (see StudentCurriculum)
/// takes an independent snapshot, so editing the template later never retroactively changes a
/// student already partway through (same principle as Contract/ContractAcceptance snapshotting).
model CurriculumTemplate {
  id          String   @id @default(cuid())
  teacherId   String
  title       String
  subject     String? // free text, e.g. "Flute", "Yoga" — not FK'd to Subject to keep this standalone
  description String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  /// Optional link so the right template is suggested automatically when a LessonType is chosen
  /// (e.g. importing curriculum for a "Flute Grade 1" LessonType suggests this template first).
  lessonTypeId String?

  teacher    Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lessonType LessonType?          @relation(fields: [lessonTypeId], references: [id], onDelete: SetNull)
  sections   CurriculumSection[]
  imports    StudentCurriculum[]

  @@index([teacherId])
}

model CurriculumSection {
  id               String  @id @default(cuid())
  templateId       String
  order            Int
  title            String
  description      String?
  estimatedLessons Int? // guide only, not enforced by any scheduling logic

  template CurriculumTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

/// Created at import time as an independent snapshot copy of a CurriculumTemplate — own title/
/// subject/section rows, not a live reference. A teacher can also build a plan from scratch
/// directly on a student (templateId left null) and "Save as Template" afterwards.
model StudentCurriculum {
  id          String                @id @default(cuid())
  studentId   String
  templateId  String? // the template this was imported from, if any — informational only
  title       String
  subject     String?
  startedDate DateTime              @default(now())
  status      StudentCurriculumStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  student  Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  template CurriculumTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sections StudentCurriculumSection[]

  @@index([studentId])
}

model StudentCurriculumSection {
  id                  String   @id @default(cuid())
  studentCurriculumId String
  order               Int
  title               String
  description         String?
  estimatedLessons    Int?
  status              StudentCurriculumSectionStatus @default(NOT_STARTED)
  completedDate       DateTime?
  notes               String?

  studentCurriculum StudentCurriculum @relation(fields: [studentCurriculumId], references: [id], onDelete: Cascade)
  lessonNotes       LessonNote[]

  @@index([studentCurriculumId])
}

/// The teacher's own professional certification/qualification record (first-aid, safeguarding,
/// instrument-specific teaching qualifications, DBS/background check, etc.) — becomes more
/// important once multi-instructor support exists (Part 6e, not yet built — see CLAUDE.md), but
/// useful standalone as a renewal-date tracker even for a single teacher.
model InstructorCertification {
  id                String   @id @default(cuid())
  teacherId         String
  certType          String
  certNumber        String?
  issuedDate        DateTime
  expiryDate        DateTime?
  reminderDaysBefore Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}

/// Deliberately NOT surfaced on the general Student card or any /parent microsite view — same
/// "teacher-only, never exposed" treatment as TeachingLocation.accessNotes. Kept as its own model
/// (rather than a Student field) so future multi-instructor visibility scoping (Part 6e) has
/// somewhere to attach without a schema change.
model StudentMedicalNote {
  id        String                    @id @default(cuid())
  studentId String
  note      String
  severity  MedicalNoteSeverity       @default(LOW)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

/// A safeguarding/liability record, separate from LessonNote (which is teaching content, shared
/// with the guardian) — never shown to a parent/student, mirrors StudentMedicalNote's visibility.
model IncidentLog {
  id             String    @id @default(cuid())
  teacherId      String
  studentId      String?
  lessonId       String?
  date           DateTime
  description    String
  actionTaken    String?
  reportedToWhom String?
  createdAt      DateTime  @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  lesson  Lesson?  @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([teacherId, date])
  @@index([studentId])
}

/// Configures the existing "Absent, make-up owed" attendance action (previously always free — see
/// CLAUDE.md's Ledger Engine Decisions) to instead charge based on how much notice was given.
/// Scoped to a TeachingLocation (specific override) or bare (teacher-wide default) — never both;
/// resolution in src/lib/cancellation-policy.ts prefers a location-scoped policy when one exists.
/// No policy configured at all = the original always-free CREDIT behavior, unchanged.
model CancellationPolicy {
  id                  String              @id @default(cuid())
  teacherId           String
  locationId          String?             @unique
  noticeHoursRequired Int
  lateCancelAction    CancellationAction
  noShowAction        CancellationAction
  /// Only meaningful when either action above is PARTIAL_CHARGE.
  partialChargePercent Int?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  teacher  Teacher           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location TeachingLocation? @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}

/// A guardian's rating/comment on a delivered lesson, submitted from the microsite's lesson notes
/// view (the natural place they're already looking at what happened in a lesson). One per
/// lesson+payer — a guardian can update their own feedback but not leave duplicates.
model LessonFeedback {
  id          String   @id @default(cuid())
  lessonId    String
  payerId     String
  rating      Int
  comments    String?
  submittedAt DateTime @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  payer  Payer  @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@unique([lessonId, payerId])
  @@index([lessonId])
}

/// Prepaid credit the teacher issues, redeemable against any Subscription's ledger for that
/// teacher (not scoped to a specific student/subscription until redemption). `remainingBalance`
/// decrements on each redemption (posts a MANUAL_CORRECTION-style CREDIT — see
/// src/lib/gift-card.ts) rather than the card being single-use.
model GiftCard {
  id                String   @id @default(cuid())
  teacherId         String
  code              String   @unique
  initialValue      Decimal  @db.Decimal(10, 2)
  remainingBalance  Decimal  @db.Decimal(10, 2)
  purchasedByPayerId String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  teacher         Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  purchasedByPayer Payer? @relation(fields: [purchasedByPayerId], references: [id], onDelete: SetNull)

  @@index([teacherId])
}

enum PromoDiscountType {
  PERCENT
  FIXED
}

/// A one-time discount code the teacher can apply to a Subscription (or scope to a specific
/// LessonType, informational only — LessonType has no direct billing hook of its own, pricing
/// lives on the Subscription). `timesUsed` + `usageLimit` are simple counters, not a redemption
/// log — good enough for "used N of M", not an audit trail (that's what LedgerEntry is for).
model PromoCode {
  id             String            @id @default(cuid())
  teacherId      String
  code           String
  discountType   PromoDiscountType
  value          Decimal           @db.Decimal(10, 2)
  validFrom      DateTime?
  validTo        DateTime?
  usageLimit     Int?
  timesUsed      Int               @default(0)
  lessonTypeId   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  teacher    Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lessonType LessonType? @relation(fields: [lessonTypeId], references: [id], onDelete: SetNull)

  @@unique([teacherId, code])
  @@index([teacherId])
}

/// A named, shareable configuration for the public self-serve onboarding flow
/// (src/app/onboard/[teacherId]/) — same submission logic, reused end to end, just pre-scoped and
/// re-branded. Generates both a plain link and a copy-paste <iframe> snippet from the same config
/// (src/app/onboard/embed/[token]/) so a teacher can post either to their own website or a
/// Facebook bio link without maintaining two separate setups.
model EmbedConfig {
  id                   String   @id @default(cuid())
  teacherId            String
  label                String // teacher's own name for this embed, e.g. "Facebook bio link"
  locationId           String?
  brandColor           String?
  embedToken           String   @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  teacher   Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  location  TeachingLocation?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  /// Empty = every active LessonType the location scoping already allows; non-empty narrows further.
  allowedLessonTypes LessonType[]

  @@index([teacherId])
}

enum CourseItemMediaType {
  VIDEO
  AUDIO
  DOCUMENT
}

/// Teacher-uploaded media (a link to wherever it's actually hosted — no file storage of its own
/// in this app). `courseId` null = free-standing library content (e.g. linked to a LessonType,
/// just reference material), not part of any priced Course.
model CourseItem {
  id           String              @id @default(cuid())
  teacherId    String
  title        String
  description  String?
  mediaType    CourseItemMediaType
  mediaUrl     String
  lessonTypeId String?
  courseId     String?
  order        Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  teacher    Teacher     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lessonType LessonType? @relation(fields: [lessonTypeId], references: [id], onDelete: SetNull)
  course     Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([courseId])
}

/// Standalone sellable content, distinct from the free CurriculumTemplate/Resource library.
/// **Deviates from the roadmap doc's own suggestion** of posting CoursePurchase to the ledger —
/// LedgerEntry.subscriptionId is required, but a payer buying a standalone course may have no
/// Subscription to attach it to. Follows the AddOn precedent instead (see "Add-on Decisions" in
/// CLAUDE.md): CoursePurchase.amountPaid is a snapshot, collection is a manual out-of-band teacher
/// action, same as AddOnBooking.priceAtTime.
model Course {
  id          String   @id @default(cuid())
  teacherId   String
  title       String
  description String?
  price       Decimal? @db.Decimal(10, 2)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher   Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  items     CourseItem[]
  purchases CoursePurchase[]

  @@index([teacherId])
}

model CoursePurchase {
  id          String   @id @default(cuid())
  courseId    String
  payerId     String
  purchasedAt DateTime @default(now())
  amountPaid  Decimal  @db.Decimal(10, 2)

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  payer  Payer  @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@unique([courseId, payerId])
}

/// Reusable starting point for a SessionPlan ("save as template" on a recurring class) — a plain
/// title/content pair, copied (not referenced) into a new SessionPlan when applied, same
/// snapshot-not-live-link principle used throughout this app (Contract, CurriculumTemplate).
model SessionPlanTemplate {
  id        String   @id @default(cuid())
  teacherId String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
}

/// What's happening in *this specific class* — shared by everyone attending, distinct from
/// LessonNote (a private per-lesson note). Exactly one of lessonId/groupClassId is set: a Lesson
/// gets at most one plan (1:1), a GroupClass (which has no dated per-occurrence row — see
/// GroupClass.sessionPlans) can accumulate several over time, with the latest treated as current.
/// Only publishedAt-set plans are shown on the public Now/Next display (drafts stay teacher-only).
model SessionPlan {
  id           String    @id @default(cuid())
  lessonId     String?   @unique
  groupClassId String?
  title        String
  content      String
  createdBy    String // teacherId, informational (no multi-instructor support yet)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  groupClass GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: Cascade)

  @@index([groupClassId, createdAt])
}
