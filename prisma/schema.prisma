// Peripatetic Teacher App — Prisma schema
// Reference: peripatetic-teacher-app-spec.md sections 2-3
// NextAuth uses Credentials + JWT sessions (no OAuth), so no Account/Session/VerificationToken tables are needed.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum TaxHandling {
  SELF_EMPLOYED
  PAYE_VIA_SCHOOL
}

enum InvoicingTarget {
  SCHOOL
  PARENT
}

enum SchedulingMode {
  FIXED
  FLUID
}

enum ChargeUnit {
  PER_BOOKING
  PER_HOUR
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum StudentSource {
  HOME
  SCHOOL_INQUIRY
  COLLEGE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAUSED
}

enum BillingModel {
  SMOOTHED_SUBSCRIPTION
  PER_LESSON
  HOURLY
  TERMLY
}

enum LessonStatus {
  HELD
  CANCELLED_BY_STUDENT
  CANCELLED_BY_TEACHER
  RESCHEDULED
}

enum LedgerReason {
  PAYMENT
  LESSON_DELIVERED
  CANCELLATION_ADJUSTMENT
  MANUAL_CORRECTION
  MAKE_UP_CREDIT_ISSUED
  MAKE_UP_CREDIT_REDEEMED
}

enum LedgerOperation {
  CREDIT // + payment received / make-up credit issued
  DEBIT // - lesson consumed / refund / credit redeemed
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

/// Teacher's own platform (SaaS) subscription status — Learnio billing them, not lesson billing.
enum PlatformSubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ResourceType {
  DOCUMENT
  AUDIO
  VIDEO
}

enum AssignmentStatus {
  ASSIGNED
  REVIEWED_DONE
  REVIEWED_NOT_DONE
}

enum PrivateTuitionRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum ContactPref {
  WHATSAPP
  SMS
  EMAIL
}

// ---------------------------------------------------------------------------
// Teacher / School / scheduling
// ---------------------------------------------------------------------------

model Teacher {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Learnio's own SaaS billing of the teacher — separate from lesson/ledger billing.
  stripeCustomerId       String?                    @unique
  platformSubscriptionId String?                    @unique
  platformStatus         PlatformSubscriptionStatus @default(TRIALING)

  /// Stripe Connect Express account so parent payments land with the teacher, not Learnio.
  stripeConnectAccountId String? @unique
  stripeConnectOnboarded Boolean @default(false)

  /// Used for home-sourced students' calendar events, when no School.primaryColor applies.
  personalBrandLogoUrl String?
  personalBrandColor   String?

  /// Whether a Subscription's banked creditAppliedNextPeriod auto-reduces the suggested amount
  /// on the next manually-generated payment request, or is only displayed for the teacher to
  /// account for themselves. See "Credit application" in the no-show/make-up-credit build notes.
  autoApplyCreditToNextPayment Boolean @default(true)

  /// Teacher's own Gmail, connected via a separate OAuth grant (NOT the NextAuth login provider —
  /// login stays Credentials-only). Lets guardian emails be sent from the teacher's real address
  /// instead of a generic sender. gmailRefreshTokenEncrypted is a real bearer secret (unlike the
  /// Stripe fields above, which are non-secret account IDs) — encrypted at rest, see src/lib/encryption.ts.
  gmailConnected             Boolean   @default(false)
  gmailConnectedEmail        String?
  gmailRefreshTokenEncrypted String?
  gmailTokenUpdatedAt        DateTime?

  schoolLinks           TeacherSchoolLink[]
  unavailability        Unavailability[]
  lessons               Lesson[]
  groupClasses          GroupClass[]
  assessments           Assessment[]
  packages              Package[]
  loanableItems         LoanableItem[]
  students              Student[]
  payers                Payer[]
  contracts             Contract[]
  resources             Resource[]
  assignments           Assignment[]
  maintenanceReminders  MaintenanceReminder[]
  expenses              Expense[]
  privateTuitionRequests PrivateTuitionRequest[]
  addOns                 AddOn[]
}

model School {
  id              String          @id @default(cuid())
  name            String
  address         String?
  invoicingTarget InvoicingTarget
  termStart       DateTime?
  termEnd         DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  /// Optional branding, used to color this school's lessons on the teacher's calendar views.
  logoUrl       String?
  primaryColor  String?
  secondaryColor String?

  teacherLinks   TeacherSchoolLink[]
  rooms          Room[]
  students       Student[]
  unavailability Unavailability[]
  lessons        Lesson[]
  groupClasses   GroupClass[]
  loanableItems  LoanableItem[]
  privateTuitionRequestsAsSource PrivateTuitionRequest[]
}

/// A Teacher's engagement with one School/Venue: scheduling mode, availability,
/// tax handling and protected blocks all vary per link, not globally.
model TeacherSchoolLink {
  id             String         @id @default(cuid())
  teacherId      String
  schoolId       String
  schedulingMode SchedulingMode
  taxHandling    TaxHandling

  /// Array of { dayOfWeek, startTime, endTime }
  availability Json

  /// Array of { dayOfWeek, startTime, endTime, label } — periods that must never be scheduled
  protectedBlocks Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([teacherId, schoolId])
}

/// Teacher-declared unavailability window. On confirmation, affected Lessons/GroupClasses
/// are auto-cancelled, guardians are emailed, and ledger credits are posted.
model Unavailability {
  id            String    @id @default(cuid())
  teacherId     String
  schoolId      String? // null = spans all schools
  startDatetime DateTime
  endDatetime   DateTime
  reason        String?
  confirmedAt   DateTime?
  createdAt     DateTime  @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school  School? @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([teacherId, startDatetime, endDatetime])
}

model Room {
  id       String @id @default(cuid())
  schoolId String
  label    String

  /// e.g. { hasPiano: true, hasMirrors: false, floor: "1st" }
  features Json @default("{}")

  /// Weekly open/closed days + time windows: array of { dayOfWeek, openTime, closeTime }
  openHours Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  lessons      Lesson[]
  groupClasses GroupClass[]
  assessments  Assessment[]
}

// ---------------------------------------------------------------------------
// Students / Guardians / Payers
// ---------------------------------------------------------------------------

model Student {
  id         String        @id @default(cuid())
  /// Owning teacher — the core multi-tenant boundary. A Student belongs to exactly one teacher.
  teacherId  String
  name       String
  dob        DateTime?
  discipline String // instrument / class / discipline
  source     StudentSource
  schoolId   String? // null for home students
  igCardId   String? // links to existing IG Card wallet pass, for CheckIn scanning only
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  /// Only settable true if the student is 16+ (checked against dob when toggled on, not
  /// continuously enforced). Grants a second, independent microsite login — additive to the
  /// guardian's own access, never a replacement. Under-16 students: no exceptions.
  hasIndependentAccess Boolean @default(false)

  /// Second 6-digit code, drawn from the same flat namespace as Payer.accessCode (one login
  /// screen accepts either kind of code) — see src/lib/access-code.ts for cross-model uniqueness.
  studentAccessCode          String?   @unique
  studentAccessCodeUpdatedAt DateTime?

  /// Financial ledger/balance is hidden from the student's own view unless the guardian
  /// explicitly opts in. Never affects the guardian's own visibility, which is always full.
  shareBalanceWithStudent Boolean @default(false)

  teacher           Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school            School?            @relation(fields: [schoolId], references: [id])
  payerLinks        StudentPayerLink[]
  subscriptions     Subscription[]
  packages          Package[]
  lessons           Lesson[]
  groupClassMembers GroupClassMember[]
  checkIns          CheckIn[]
  assessments       Assessment[]
  loans             Loan[]
  resources         Resource[]
  assignments       Assignment[]
  privateTuitionRequests PrivateTuitionRequest[]
  makeUpLessons     MakeUpLesson[]

  @@index([teacherId])
}

/// A guardian/student microsite request to convert a school-sourced Student into a private
/// (HOME-sourced) relationship. Acceptance is additive — creates a NEW Student row rather than
/// mutating the existing school-linked one, since school and private are separate billing
/// relationships that may coexist (e.g. still enrolled at the school, now also private).
model PrivateTuitionRequest {
  id               String                      @id @default(cuid())
  studentId        String
  teacherId        String
  sourceSchoolId   String
  status           PrivateTuitionRequestStatus @default(PENDING)
  requestedAt      DateTime                    @default(now())
  /// Set on acceptance — the new HOME-sourced Student created as a result, for traceability.
  resultingStudentId String?

  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher      Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  sourceSchool School  @relation(fields: [sourceSchoolId], references: [id])

  @@index([studentId, status])
}

model Payer {
  id        String   @id @default(cuid())
  /// Owning teacher — same tenancy boundary as Student. A family with two Learnio teachers
  /// (e.g. piano + yoga) gets one Payer record per teacher relationship, not one shared globally.
  teacherId String
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Persistent unique 6-digit microsite access code (unique per family, not shared globally)
  accessCode          String   @unique
  accessCodeUpdatedAt DateTime @default(now())

  /// True when this Payer record IS the adult (18+) student paying for their own tuition — created
  /// by the new-student wizard's self-pay branch from the student's own contact details.
  isSelf Boolean @default(false)

  /// True for a safeguarding/emergency contact captured for an under-18 student whose SCHOOL is
  /// billed — has no billing role (never carries a Subscription), just contact + notes, so
  /// guardian info exists without implying they're invoiced. Distinct from a normal paying Payer.
  isEmergencyContactOnly Boolean @default(false)

  /// Preferred contact channel; notes is freeform (also holds address, which has no dedicated column).
  contactPref ContactPref?
  notes       String?

  teacher             Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  studentLinks        StudentPayerLink[]
  subscriptions       Subscription[]
  contractAcceptances ContractAcceptance[]

  @@index([teacherId])
}

model StudentPayerLink {
  id           String   @id @default(cuid())
  studentId    String
  payerId      String
  isPrimary    Boolean  @default(true)
  splitPercent Decimal? @db.Decimal(5, 2) // used when more than one payer splits a student's bill
  createdAt    DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payer   Payer   @relation(fields: [payerId], references: [id], onDelete: Cascade)

  @@unique([studentId, payerId])
}

// ---------------------------------------------------------------------------
// Billing: Subscription / Package / Ledger / Payment
// ---------------------------------------------------------------------------

model Subscription {
  id           String             @id @default(cuid())
  studentId    String
  payerId      String
  annualFee    Decimal            @db.Decimal(10, 2)
  billingModel BillingModel
  status       SubscriptionStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?

  stripeSubscriptionId String? @unique
  stripeCustomerId     String?

  /// Banked from resolved no-shows via the "Review term absences" screen — see
  /// src/lib/ledger.ts and the payment-request flow for how this reduces (or is displayed
  /// alongside, per Teacher.autoApplyCreditToNextPayment) the next manually-generated payment.
  creditAppliedNextPeriod Decimal @default(0) @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payer         Payer         @relation(fields: [payerId], references: [id], onDelete: Cascade)
  ledgerEntries LedgerEntry[]
  payments      Payment[]
  lessons       Lesson[]
}

/// Prepaid block of N lessons at a discounted bundle rate. Distinct from Subscription —
/// no monthly smoothing, no running balance across the year.
model Package {
  id               String   @id @default(cuid())
  studentId        String
  teacherId        String
  totalLessons     Int
  lessonsRemaining Int
  price            Decimal  @db.Decimal(10, 2)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  student Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  lessons Lesson[]
}

/// Running-balance ledger. Balance for a Subscription = sum of CREDIT entries minus DEBIT entries.
model LedgerEntry {
  id             String          @id @default(cuid())
  subscriptionId String
  amount         Decimal         @db.Decimal(10, 2)
  operation      LedgerOperation
  reason         LedgerReason
  date           DateTime        @default(now())
  note           String?
  createdAt      DateTime        @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, date])
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  stripePaymentId String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus
  date            DateTime      @default(now())
  createdAt       DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
}

/// Teacher-tracked business expense, for the income forecasting dashboard's expense-tracking line.
model Expense {
  id        String   @id @default(cuid())
  teacherId String
  amount    Decimal  @db.Decimal(10, 2)
  category  String
  date      DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, date])
}

/// One evolving document per teacher (not per subscription) — a teacher's standard terms apply
/// across all their students. Editing the contract creates a new version; content is never
/// mutated in place, since ContractAcceptance snapshots must stay meaningful against history.
model Contract {
  id        String   @id @default(cuid())
  teacherId String
  version   Int
  content   String // plain-terms explanation of the subscription/ledger model
  createdAt DateTime @default(now())

  teacher     Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  acceptances ContractAcceptance[]

  @@unique([teacherId, version])
}

/// The actual mechanism of legal agreement — an in-app clickwrap acceptance, not a PDF/e-signature
/// round-trip. Gates lesson booking and payment collection on a Subscription until the
/// Subscription's payer has accepted the teacher's *current* Contract version.
model ContractAcceptance {
  id      String @id @default(cuid())
  payerId String

  contractId      String
  /// Denormalized so "did they accept the current version" is a direct comparison, not a join.
  contractVersion Int

  /// Independent copy of the exact text shown at acceptance time — deliberately not just a
  /// foreign key to Contract.content, so a later edit to the live contract can never retroactively
  /// change what a past acceptance recorded as having been agreed to.
  contractSnapshot String

  typedName  String
  acceptedAt DateTime @default(now())
  ipAddress  String?

  payer    Payer    @relation(fields: [payerId], references: [id], onDelete: Cascade)
  contract Contract @relation(fields: [contractId], references: [id])

  @@unique([payerId, contractVersion])
  @@index([payerId])
}

// ---------------------------------------------------------------------------
// Lessons / GroupClasses / CheckIn
// ---------------------------------------------------------------------------

model Lesson {
  id             String       @id @default(cuid())
  studentId      String
  teacherId      String
  schoolId       String
  roomId         String?
  subscriptionId String?
  packageId      String?
  scheduledAt    DateTime
  durationMins   Int
  status         LessonStatus @default(HELD)

  /// Mirrors ELVIS's are_hours_counted — false for a cover/make-up lesson so it doesn't double-bill
  hoursCounted Boolean @default(true)

  /// Set via the "Absent, make-up owed" attendance action — a confirmed no-show, distinct from
  /// simply never having marked attendance at all. Feeds the MakeUpLesson tracking row created
  /// alongside it and the "Review term absences" screen.
  noShowReason    String?
  noShowConfirmed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student            Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher            Teacher        @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school             School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  room               Room?          @relation(fields: [roomId], references: [id])
  subscription       Subscription?  @relation(fields: [subscriptionId], references: [id])
  package            Package?       @relation(fields: [packageId], references: [id])
  addOnBookings      AddOnBooking[]
  checkIn            CheckIn?
  note               LessonNote?
  resources          Resource[]
  makeUpLessonAsOriginal MakeUpLesson? @relation("OriginalLesson")
  makeUpLessonAsMakeUp   MakeUpLesson? @relation("MakeUpLessonSlot")

  @@index([teacherId, scheduledAt])
  @@index([studentId, scheduledAt])
}

/// Tracks a confirmed no-show from marking-it through to resolution — either a rescheduled
/// make-up lesson, or (via the "Review term absences" screen) converted into a next-period
/// billing credit. Created alongside the MAKE_UP_CREDIT_ISSUED ledger entry when a lesson is
/// marked "Absent, make-up owed", so the credit isn't just a floating ledger row.
model MakeUpLesson {
  id              String    @id @default(cuid())
  originalLessonId String   @unique
  makeUpLessonId  String?   @unique
  studentId       String
  requestedAt     DateTime  @default(now())
  confirmedAt     DateTime?
  completedAt     DateTime?

  originalLesson Lesson  @relation("OriginalLesson", fields: [originalLessonId], references: [id], onDelete: Cascade)
  makeUpLesson   Lesson? @relation("MakeUpLessonSlot", fields: [makeUpLessonId], references: [id])
  student        Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, completedAt])
}

/// Freetext note per lesson — what was covered, what to work on next. Visible to the guardian
/// always, and to the student too if they have independent access (not gated by
/// shareBalanceWithStudent — that toggle is specifically about the financial ledger).
model LessonNote {
  id        String   @id @default(cuid())
  lessonId  String   @unique
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model GroupClass {
  id         String  @id @default(cuid())
  teacherId  String
  schoolId   String
  roomId     String?
  name       String
  discipline String

  dayOfWeek Int // 0-6, recurs weekly
  startTime String // "HH:mm"
  endTime   String // "HH:mm"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher       Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  school        School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  room          Room?              @relation(fields: [roomId], references: [id])
  members       GroupClassMember[]
  checkIns      CheckIn[]
  addOnBookings AddOnBooking[]
}

/// Each member keeps their own independent Subscription/Ledger even though they share a timeslot.
model GroupClassMember {
  id           String    @id @default(cuid())
  groupClassId String
  studentId    String
  joinedAt     DateTime  @default(now())
  leftAt       DateTime?

  groupClass GroupClass @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupClassId, studentId])
}

/// Card-based sign-in/out. Scanning on sign-in auto-fires the LESSON_DELIVERED ledger entry.
model CheckIn {
  id           String    @id @default(cuid())
  lessonId     String?   @unique
  groupClassId String?
  studentId    String
  signedInAt   DateTime?
  signedOutAt  DateTime?
  createdAt    DateTime  @default(now())

  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  groupClass GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
  student    Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([groupClassId, studentId])
}

// ---------------------------------------------------------------------------
// Add-ons
// ---------------------------------------------------------------------------

model AddOn {
  id         String     @id @default(cuid())
  teacherId  String
  name       String
  price      Decimal    @db.Decimal(10, 2)
  chargeUnit ChargeUnit
  visibility Visibility @default(PUBLIC)
  archivedAt DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  teacher  Teacher         @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  bookings AddOnBooking[]

  @@index([teacherId])
}

/// Attaches an AddOn to a Lesson or GroupClass booking without touching the core billing model.
model AddOnBooking {
  id           String   @id @default(cuid())
  addOnId      String
  lessonId     String?
  groupClassId String?
  quantity     Int      @default(1)
  priceAtTime  Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  addOn      AddOn       @relation(fields: [addOnId], references: [id])
  lesson     Lesson?     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  groupClass GroupClass? @relation(fields: [groupClassId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Assessments / Loans
// ---------------------------------------------------------------------------

model Assessment {
  id          String   @id @default(cuid())
  studentId   String
  teacherId   String
  level       String // grade/level achieved
  date        DateTime
  canContinue Boolean  @default(true)

  /// Set when this is a formal sit-down evaluation rather than an informal note
  appointmentAt DateTime?
  roomId        String?

  examBoard String? // e.g. Trinity, ABRSM
  examFee   Decimal? @db.Decimal(10, 2)

  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  room    Room?   @relation(fields: [roomId], references: [id])
}

/// A shared library item (document/audio/video). Attachable to a Student generally (a library
/// item for them), to a specific Lesson, or left unattached in the teacher's general library
/// until an Assignment references it via Assignment.resourceId.
model Resource {
  id          String       @id @default(cuid())
  teacherId   String
  type        ResourceType
  title       String
  url         String
  description String?
  studentId   String?
  lessonId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  teacher     Teacher      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  student     Student?     @relation(fields: [studentId], references: [id])
  lesson      Lesson?      @relation(fields: [lessonId], references: [id])
  assignments Assignment[]
}

/// A personal routine/exercise a teacher assigns one student between lessons, reviewed at the next one.
model Assignment {
  id           String           @id @default(cuid())
  studentId    String
  teacherId    String
  title        String
  instructions String
  target       String
  assignedDate DateTime
  reviewDate   DateTime
  resourceId   String?
  status       AssignmentStatus @default(ASSIGNED)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  resource Resource? @relation(fields: [resourceId], references: [id])

  @@index([studentId])
}

model LoanableItem {
  id        String   @id @default(cuid())
  name      String
  type      String // instrument / book / CD / etc.
  condition String?
  value     Decimal? @db.Decimal(10, 2)
  teacherId String? // owned by Teacher or School (exactly one should be set)
  schoolId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teacher              Teacher?              @relation(fields: [teacherId], references: [id])
  school               School?               @relation(fields: [schoolId], references: [id])
  loans                Loan[]
  maintenanceReminders MaintenanceReminder[]
}

model Loan {
  id             String    @id @default(cuid())
  itemId         String
  studentId      String
  checkedOutDate DateTime  @default(now())
  dueBackDate    DateTime
  returnedDate   DateTime?
  conditionNotes String?

  item    LoanableItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  student Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

/// Upkeep reminder on equipment, owned or loaned. Not every reminder needs a formal LoanableItem
/// (itemDescription covers ad hoc equipment) — when it IS linked to one that's currently on loan
/// to a student, it surfaces in that student's microsite; unlinked reminders stay teacher-only.
model MaintenanceReminder {
  id              String   @id @default(cuid())
  teacherId       String
  loanableItemId  String?
  itemDescription String
  dueDate         DateTime
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teacher      Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  loanableItem LoanableItem? @relation(fields: [loanableItemId], references: [id])
}
