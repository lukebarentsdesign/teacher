# Supabase Postgres — direct (non-pooled, port 5432) connection string.
# Project Settings > Database > Connection string > "Nodejs" / URI, direct connection.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth v5
AUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"

# Resend (transactional email — Unavailability guardian notifications, etc.)
RESEND_API_KEY=""
EMAIL_FROM="Learnio <notifications@example.com>"

# App URL used to build Stripe Checkout/Connect return URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe — platform billing (teachers paying Learnio)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Price ID for the flat monthly/annual Learnio plan (create the Product/Price in the Stripe Dashboard)
STRIPE_PLATFORM_PRICE_ID=""
