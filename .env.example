# Supabase Postgres — direct (non-pooled, port 5432) connection string.
# Project Settings > Database > Connection string > "Nodejs" / URI, direct connection.
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Auth (Better Auth). AUTH_SECRET signs sessions. BETTER_AUTH_URL is the canonical origin Better
# Auth trusts for sign-in/sign-up requests — set it to the deployed app URL (or a preview URL) or
# sign-in fails with 403 INVALID_ORIGIN. Falls back to NEXT_PUBLIC_APP_URL, then localhost:3000.
# (NEXTAUTH_URL is a legacy name kept only as an additional trusted-origin fallback.)
AUTH_SECRET="generate-with: npx auth secret"
BETTER_AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Comma-separated Teacher emails allowed to view /dashboard/out-of-scope-signups — this app has no
# real admin/role system, so this one operator-only screen is gated by a plain env var instead.
ADMIN_EMAILS=""

# Resend — listed in package.json but not actually wired up anywhere in the app. Guardian
# notifications (e.g. Unavailability) go via the teacher's own connected Gmail (src/lib/gmail.ts)
# instead. Kept here in case Resend gets wired up later; unused today.
RESEND_API_KEY=""
EMAIL_FROM="Learnio <notifications@example.com>"

# Timetable microservice (timetable-service/, Google OR-Tools CP-SAT) — optional. When set, the
# FLUID-mode generator (src/lib/timetable.ts) calls out to this service for a jointly-optimized
# slot assignment instead of its own simpler round-robin; unset or unreachable, it falls back to
# the round-robin automatically. Point this at wherever you've deployed timetable-service (see its
# README — it needs a real Python runtime, not Vercel/serverless). e.g. "http://localhost:8001"
TIMETABLE_SERVICE_URL=""

# App URL used to build Stripe Checkout/Connect return URLs
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe — platform billing (teachers paying Learnio)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Price ID for the flat monthly/annual Learnio plan (create the Product/Price in the Stripe Dashboard)
STRIPE_PLATFORM_PRICE_ID=""

# Google OAuth — lets a teacher connect their own Gmail (src/lib/gmail.ts) to send guardian emails
# from their real address. NOT used for teacher login (that's Better Auth email/password — see
# AUTH_SECRET/BETTER_AUTH_URL above). Create an
# OAuth 2.0 Client ID in Google Cloud Console (APIs & Services > Credentials), enable the Gmail
# API, and add "{NEXT_PUBLIC_APP_URL}/api/gmail/callback" as an authorized redirect URI. While the
# OAuth consent screen is in "Testing" status (the default, no Google review needed), add each
# teacher's Google account as a test user under "Audience" — up to 100 test users, no review.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# 32-byte key, base64-encoded (generate with: openssl rand -base64 32). Encrypts
# Teacher.gmailRefreshTokenEncrypted at rest — this is a real bearer secret, unlike the Stripe
# fields above which are non-secret account IDs (the actual Stripe key lives only in this file).
ENCRYPTION_KEY=""
